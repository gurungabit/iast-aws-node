# Database
DATABASE_URL=postgres://iast:iast_dev@localhost:5432/iast

# Server
PORT=3000
HOST=0.0.0.0

# TN3270 Mainframe
TN3270_HOST=hometn3270p.opr.statefarm.org
TN3270_PORT=1023
TN3270_SECURE=true

# Azure Entra ID
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_AUDIENCE=

# Terminal
MAX_WORKERS=50

# DB2
DB2_DATABASE=
DB2_HOSTNAME=
DB2_PORT=
DB2_PROTOCOL=TCPIP
DB2_UID=
DB2_PWD=
DB2_SCHEMA=

# SMB Credentials (share paths are in smb-paths.ts)
SMB_DOMAIN=
SMB_USERNAME=
SMB_PASSWORD=

# Encryption
ENCRYPTION_KEY=

# AWS (optional - for schedules)
AWS_REGION=
EVENTBRIDGE_ROLE_ARN=
SCHEDULE_TARGET_ARN=

# Secrets Manager
SECRETS_PREFIX=iast/
